{
  "name": "escape-from-pinsk",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:replit": "VITE_BASE=/ tsc -b && VITE_BASE=/ vite build",
    "build:pages": "VITE_BASE=/escape-from-pinsk/ tsc -b && VITE_BASE=/escape-from-pinsk/ vite build",
    "start": "serve dist -l 3000",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:report": "vitest run --reporter=verbose && node scripts/exec-qa-report.mjs"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "serve": "^14.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
